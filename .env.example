NODE_ENV=production
HOST=0.0.0.0
PORT=3000

# Data
DB_PATH=./data/travel.db
UPLOADS_DIR=./uploads

# Upload / payload limits
MAX_UPLOAD_MB=15
MAX_JSON_MB=1

# Reverse proxy
TRUST_PROXY=true

# Rate limits (window in ms)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_READ=300
RATE_LIMIT_WRITE=80
RATE_LIMIT_UPLOAD=24

# IMPORTANT: replace with a strong random string
EDIT_KEY_PEPPER=replace-this-with-a-long-random-secret
LEGACY_EDIT_KEY=demo12345

# Disable demo records in production
SEED_DEMO_DATA=false

# Public domain and TLS email for Caddy
DOMAIN=travel.example.com
LETSENCRYPT_EMAIL=you@example.com
